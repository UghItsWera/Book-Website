<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - My Website</title>

    <link rel="stylesheet" href="~/css/styles.css" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&family=Merriweather&display=swap" rel="stylesheet" />
    <script src="~/js/ThemeSwitch.js" defer></script>
</head>
<body>
    <!-- Navigation bar shared across all pages -->
    <nav>
        <a asp-controller="Home" asp-action="Index">Home</a>
        <a asp-controller="Projects" asp-action="Existing">Books</a>
        <a asp-controller="Projects" asp-action="Upcoming">Upcoming</a>
        <a asp-controller="Content" asp-action="Additional">Additional Content</a>
        <a asp-controller="About" asp-action="Index">About</a>
    </nav>

    <!-- Theme toggle -->
    <button id="theme-toggle" aria-label="Toggle Theme">🌙</button>

    <!-- Page-specific content -->
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    @RenderSection("Scripts", required: false)
</body>
</html>