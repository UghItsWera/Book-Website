@{
    ViewData["Title"] = "Edit Site Content";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-section">
    <h1>Edit Site Content</h1>
    <p>Edit the content that appears on various pages of your site.</p>

    <div class="content-editor-container">
        <div class="content-section">
            <h2>Home Page Welcome Message</h2>
            <form method="post" asp-action="UpdateSiteContent">
                <input type="hidden" name="key" value="HomeWelcome" />
                <div class="form-group">
                    <textarea name="content" class="form-control" rows="5" placeholder="Enter your welcome message...">@ViewBag.HomeWelcome</textarea>
                </div>
                <button type="submit" class="btn-primary">Update Welcome Message</button>
            </form>
        </div>

        <div class="content-section">
            <h2>About Me Page</h2>
            <form method="post" asp-action="UpdateSiteContent">
                <input type="hidden" name="key" value="AboutMe" />
                <div class="form-group">
                    <div class="editor-toolbar">
                        <button type="button" onclick="formatAboutText('bold')" title="Bold">
                            <strong>B</strong>
                        </button>
                        <button type="button" onclick="formatAboutText('italic')" title="Italic">
                            <em>I</em>
                        </button>
                        <button type="button" onclick="formatAboutText('underline')" title="Underline">
                            <u>U</u>
                        </button>
                        <span class="divider"></span>
                        <button type="button" onclick="formatAboutText('insertUnorderedList')" title="Bullet List">
                            • List
                        </button>
                        <button type="button" onclick="formatAboutText('insertOrderedList')" title="Numbered List">
                            1. List
                        </button>
                        <span class="divider"></span>
                        <button type="button" onclick="formatAboutText('formatBlock', 'h2')" title="Heading 2">
                            H2
                        </button>
                        <button type="button" onclick="formatAboutText('formatBlock', 'h3')" title="Heading 3">
                            H3
                        </button>
                        <button type="button" onclick="formatAboutText('formatBlock', 'p')" title="Paragraph">
                            P
                        </button>
                    </div>
                    <div id="aboutEditor" contenteditable="true" class="rich-text-editor">
                        @Html.Raw(ViewBag.AboutMe)
                    </div>
                    <textarea name="content" id="aboutHidden" style="display: none;"></textarea>
                </div>
                <button type="submit" class="btn-primary" onclick="syncAboutContent(event)">Update About Me</button>
            </form>
        </div>
    </div>
</div>

<style>
.content-editor-container {
    display: flex;
    flex-direction: column;
    gap: 3rem;
    margin-top: 2rem;
}

.content-section {
    background: var(--bg-secondary);
    padding: 2rem;
    border-radius: 8px;
}

.content-section h2 {
    margin-top: 0;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
}

.editor-toolbar {
    display: flex;
    gap: 0.25rem;
    padding: 0.5rem;
    background: var(--bg-primary);
    border: 1px solid var(--border-color);
    border-bottom: none;
    border-radius: 4px 4px 0 0;
    flex-wrap: wrap;
}

.editor-toolbar button {
    padding: 0.5rem 0.75rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 3px;
    cursor: pointer;
    font-size: 0.875rem;
    color: var(--text-primary);
}

.editor-toolbar button:hover {
    background: var(--accent-color);
    color: white;
}

.editor-toolbar .divider {
    width: 1px;
    background: var(--border-color);
    margin: 0 0.5rem;
}

.rich-text-editor {
    min-height: 300px;
    padding: 1rem;
    border: 1px solid var(--border-color);
    border-radius: 0 0 4px 4px;
    background: white;
    color: black;
    font-family: 'Merriweather', serif;
    line-height: 1.8;
    overflow-y: auto;
}

.rich-text-editor:focus {
    outline: none;
    border-color: var(--accent-color);
}

.rich-text-editor p {
    margin-bottom: 1rem;
}

.rich-text-editor h2, .rich-text-editor h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
}
</style>

<script>
function formatAboutText(command, value = null) {
    document.execCommand(command, false, value);
    document.getElementById('aboutEditor').focus();
}

function syncAboutContent(e) {
    e.preventDefault();
    const editorContent = document.getElementById('aboutEditor').innerHTML;
    document.getElementById('aboutHidden').value = editorContent;
    e.target.closest('form').submit();
}

window.addEventListener('DOMContentLoaded', function() {
    const editor = document.getElementById('aboutEditor');
    if (!editor.innerHTML.trim()) {
        editor.innerHTML = '<p>Tell your readers about yourself...</p>';
    }
});
</script>